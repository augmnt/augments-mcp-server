# Augments MCP Server Environment Variables
# v4.1.0 Configuration

# ============ Required (for production caching) ============

# Upstash Redis Configuration (required for persistent caching in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============ Optional ============

# GitHub API Token (optional, increases rate limits for example fetching)
GITHUB_TOKEN=

# Enable legacy v3 tools (default: false)
# When true, exposes 8 additional backward-compatible tools
LEGACY_TOOLS_ENABLED=false

# Maximum cache entries for unified cache (default: 300)
CACHE_MAX_ENTRIES=300

# Logging level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Server Configuration
PORT=3000
NODE_ENV=development
